# ── Variables d'environnement Railway ────────────────────────────────────────
# Copiez ce fichier dans le dashboard Railway : Settings → Variables.
# Les variables marquées [RAILWAY AUTO] sont injectées automatiquement.
# Ne jamais committer les vraies valeurs — garder uniquement ce fichier exemple.

# ── Django core ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=remplacez-par-une-cle-aleatoire-de-50-caracteres-minimum
DEBUG=False
DJANGO_DEPLOY_ENV=production
ENV=production

# ALLOWED_HOSTS — Railway injecte RAILWAY_PUBLIC_DOMAIN (géré automatiquement par settings.py).
# Ajoutez votre domaine custom ici si vous en avez un :
ALLOWED_HOSTS=votre-domaine-custom.com

# CSRF — idem, RAILWAY_PUBLIC_DOMAIN est géré. Ajoutez votre domaine custom :
CSRF_TRUSTED_ORIGINS_EXTRA=https://votre-domaine-custom.com

# ── Base de données (Supabase — déjà configuré) ───────────────────────────────
DATABASE_URL=postgres://user:password@host:6543/postgres?sslmode=require

# ── Redis (à créer dans Railway : Add Service → Redis) ───────────────────────
# Railway injecte REDIS_URL automatiquement si vous ajoutez un service Redis.
REDIS_URL=redis://default:password@host:port  # [RAILWAY AUTO si service Redis ajouté]

# ── Celery ────────────────────────────────────────────────────────────────────
# Optionnel : Railway AUTO-set REDIS_URL → CELERY_BROKER_URL géré par settings.py
# CELERY_BROKER_URL=redis://...   # laisser vide si REDIS_URL est défini
CELERY_TASK_ALWAYS_EAGER=False

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_MEDIA_PREFIX=prod

# ── APIs externes ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=votre-cle-gemini
OPENWEATHER_API_KEY=votre-cle-openweather

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-application-gmail

# ── Sécurité HTTPS ────────────────────────────────────────────────────────────
SECURE_HSTS_SECONDS=86400
SECURE_HSTS_INCLUDE_SUBDOMAINS=True

# ── Play Store (à renseigner après signature de l'APK) ────────────────────────
ANDROID_PACKAGE_NAME=com.votre.package
ANDROID_ASSETLINKS_SHA256=AA:BB:CC:...  # empreinte SHA-256 de votre keystore

# ── Variables injectées automatiquement par Railway (NE PAS DÉFINIR) ──────────
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=votre-app.up.railway.app
# RAILWAY_PRIVATE_DOMAIN=votre-app.internal
# PORT=8000
