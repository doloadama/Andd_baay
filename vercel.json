{
  "installCommand": "pip install -r requirements-vercel.txt",
  "version": 2,
  "builds": [
    {
      "src": "Andd_Baayi/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12",
        "excludeFiles": "{**/*.pkl,**/static/**,**/*.jpg,**/*.png,**/*.gif,**/*.jpeg,**/media/**,__pycache__/**,**/*.pyc,**/tests/**,.git/**}"
      }
    },
    {
      "src": "baay/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/baay/static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/baay/static/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "Andd_Baayi/wsgi.py"
    }
  ]
}
