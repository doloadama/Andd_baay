{
  "version": 2,
  "builds": [
    {
      "src": "Andd_Baayi/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.12"
      }
    },
    {
      "src": "baay/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/baay/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "Andd_Baayi/wsgi.py"
    }
  ]
}
