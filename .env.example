# ============================================================
# Google OAuth (Connexion / Inscription via Gmail)
# ============================================================
# 1. Allez sur https://console.cloud.google.com/
# 2. Créez un projet (ou sélectionnez un existant)
# 3. Activez l'API "Google+" / "People API" (APIs & Services > Library)
# 4. Allez dans "Credentials" > "Create Credentials" > "OAuth client ID"
# 5. Configurez l'écran de consentement OAuth (type "External")
# 6. Type d'application : "Web application"
# 7. URI de redirection autorisées :
#    - http://localhost:8000/accounts/google/login/callback/
#    - https://votredomaine.com/accounts/google/login/callback/
# 8. Copiez le Client ID et Client Secret ci-dessous
# 9. Lancez : python manage.py setup_google_oauth
# 10. Déploiement (Vercel) : définissez SITE_DOMAIN et chaque URL de prod exacte dans Google Console :
#     https://VOTRE_APP.vercel.app/accounts/google/login/callback/
#     Si l'écran de consentement OAuth est en mode "Test", ajoutez CHAQUE compte Google
#     dans "Utilisateurs testeurs", sinon seul le premier compte autorisé pourra se connecter.
# 11. Optionnel : CSRF_TRUSTED_ORIGINS_EXTRA=https://autre-host.vercel.app (URLs de preview)
# 12. Optionnel : SITE_DOMAIN=votre-app.vercel.app (cohérence Site django.contrib.sites)
# ============================================================
GOOGLE_CLIENT_ID=votre_client_id_google.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre_client_secret_google
DJANGO_SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (set ENV=production to enable Postgres settings)
ENV=development
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# ============================================================
# Email (SMTP) — laissez les credentials vides pour activer le
# backend "console" (les emails sont logges au lieu d'etre envoyes).
# ============================================================
#
# --- GMAIL (recommande pour debuter) ---
# 1. Activez la 2FA sur votre compte Google : https://myaccount.google.com/security
# 2. Creez un mot de passe d'application : https://myaccount.google.com/apppasswords
#    (selectionnez "App: Mail", "Device: Other", nommez-le "Andd Baay")
# 3. Copiez le mot de passe 16 caracteres dans EMAIL_HOST_PASSWORD ci-dessous
#    (sans espaces).
# 4. Mettez votre adresse Gmail dans EMAIL_HOST_USER et DEFAULT_FROM_EMAIL.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Andd Baay <votre-adresse@gmail.com>

# --- Alternatives SMTP courantes ---
# Brevo (ex-Sendinblue, gratuit 300 mails/jour) :
#   EMAIL_HOST=smtp-relay.brevo.com   EMAIL_PORT=587   EMAIL_USE_TLS=True
# SendGrid :
#   EMAIL_HOST=smtp.sendgrid.net      EMAIL_PORT=587   EMAIL_USE_TLS=True
#   EMAIL_HOST_USER=apikey   EMAIL_HOST_PASSWORD=<votre_api_key>
# Mailgun :
#   EMAIL_HOST=smtp.mailgun.org       EMAIL_PORT=587   EMAIL_USE_TLS=True
# Outlook / Office 365 :
#   EMAIL_HOST=smtp.office365.com     EMAIL_PORT=587   EMAIL_USE_TLS=True
#
# Pour forcer un backend specifique : EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Gemini (optional)
GEMINI_API_KEY=AIzaSyACL8e9j6gvntVNnf6ONFvKTWcCPb0A-Dw

# ML model integrity (optional)
ML_MODEL_HASH=
